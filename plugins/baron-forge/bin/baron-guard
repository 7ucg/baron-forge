#!/usr/bin/env bash
# baron-guard — PreToolUse(Bash) tripwire for bypassPermissions sessions.
# DENIES only commands that are never legitimate and wipe everything (one-typo
# apocalypse). Everything else runs untouched; merely-risky commands are logged
# (audit trail) and allowed. Keeps full speed, catches the catastrophe.
set -uo pipefail

input="$(cat)"

# Fast path: skip Python entirely when input has no danger signatures.
# Covers ~99% of normal commands with zero Python startup overhead.
printf '%s' "$input" | grep -qE \
  'rm\s+-[A-Za-z]*[rf]|:\s*\(\s*\)\s*\{|mkfs(\.[a-z]+)?\s|dd\s[^"]*of=/dev/|>\s*/dev/(sd|nvme|hd)|chmod\s+-R\s+777\s+/|Co-[Aa]uthor' \
  || exit 0

PY=""; for c in python3 python py; do if "$c" -c '' >/dev/null 2>&1; then PY="$c"; break; fi; done
[ -n "$PY" ] || exit 0

LOG="${BARON_FORGE_HOME:-$HOME/.claude/baron-forge}/danger.log"
BARON_INPUT="$input" BARON_LOG="$LOG" "$PY" - <<'PYEOF'
import json, sys, re, os, datetime
try:
    cmd = json.loads(os.environ.get("BARON_INPUT", "") or "{}").get("tool_input", {}).get("command", "") or ""
except Exception:
    sys.exit(0)

def deny(reason):
    print(json.dumps({"hookSpecificOutput": {
        "hookEventName": "PreToolUse",
        "permissionDecision": "deny",
        "permissionDecisionReason": "baron-guard: " + reason + " -> blocked. Use an explicit, narrow target."}}))
    sys.exit(0)

# Never-legitimate, total-loss patterns.
catastrophic = [
    (r'\brm\s+(?:-[A-Za-z]*\s+)*-?[A-Za-z]*[rf][A-Za-z]*\s+(?:-[A-Za-z]+\s+)*(?:/|/\*|~|\$HOME|\*)(?:\s|;|&|$)', "recursive delete of filesystem/home root"),
    (r':\s*\(\s*\)\s*\{\s*:\s*\|\s*:\s*&\s*\}\s*;\s*:', "fork bomb"),
    (r'\bmkfs(?:\.\w+)?\b[^\n]*(?:/dev/|\bsd[a-z]|\bnvme)', "mkfs on a block device"),
    (r'\bdd\b[^\n]*\bof=/dev/(?:sd|nvme|hd|disk)', "dd to a raw device"),
    (r'>\s*/dev/(?:sd|nvme|hd)', "raw disk overwrite"),
    (r'\bchmod\s+-R\s+777\s+/(?:\s|$)', "recursive 777 from root"),
]
for pat, why in catastrophic:
    if re.search(pat, cmd):
        deny(why)

# Deny git commits that contain Claude/Anthropic Co-Authored-By trailers.
if re.search(r'\bgit\s+commit\b', cmd):
    if re.search(r'[Cc]o-[Aa]uthored?-[Bb]y\s*:.*(?:[Cc]laude|[Aa]nthropic|noreply@anthropic)', cmd):
        deny("Co-Authored-By Claude/Anthropic trailer in git commit — remove it")

# Risky-but-sometimes-valid: allow, just log it.
warn = [r'\brm\s+-[A-Za-z]*[rf]', r'\bgit\s+push\s+(?:--force\b|-f\b)',
        r'\bDROP\s+(?:DATABASE|TABLE)\b', r'\bTRUNCATE\b',
        r'\bgit\s+reset\s+--hard\b', r'\bgit\s+clean\s+-[A-Za-z]*f']
if any(re.search(p, cmd, re.I) for p in warn):
    try:
        log = os.environ.get("BARON_LOG", "")
        os.makedirs(os.path.dirname(log), exist_ok=True)
        with open(log, "a", encoding="utf-8") as f:
            f.write("[%s] %s\n" % (datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S"), cmd))
    except Exception:
        pass
sys.exit(0)
PYEOF

#!/usr/bin/env bash
# baron-secret — PreToolUse(Write) hook. Warns (does not block) when a file about
# to be written contains obvious API keys, tokens, or credentials. Silent on clean writes.
set -uo pipefail

input="$(cat)"
[ -n "$input" ] || exit 0

# Fast path: grep raw JSON for known token prefixes before spawning Python.
# These patterns almost never appear in legitimate code — only real credentials.
printf '%s' "$input" | grep -qE \
  '"(sk-[a-zA-Z0-9]{20,}|ghp_[a-zA-Z0-9]{30,}|ghs_[a-zA-Z0-9]{30,}|xoxb-[a-zA-Z0-9-]{20,}|AKIA[A-Z0-9]{16}|AIza[a-zA-Z0-9_-]{35}|ya29\.[a-zA-Z0-9_-]{50,})"' \
  || exit 0

# Slow path: precise extraction and reporting via Python.
PY=""; for c in python3 python py; do if "$c" -c '' >/dev/null 2>&1; then PY="$c"; break; fi; done
[ -n "$PY" ] || exit 0

printf '%s' "$input" | "$PY" - <<'PYEOF'
import json, sys, re, os

PATTERNS = [
    (r'sk-[a-zA-Z0-9]{40,}',                       'Anthropic/OpenAI API key (sk-)'),
    (r'ghp_[a-zA-Z0-9]{36,}',                       'GitHub personal access token'),
    (r'ghs_[a-zA-Z0-9]{36,}',                       'GitHub server token'),
    (r'xoxb-[a-zA-Z0-9-]{20,}',                     'Slack bot token'),
    (r'AKIA[A-Z0-9]{16}',                            'AWS access key'),
    (r'AIza[a-zA-Z0-9_-]{35}',                       'Google API key'),
    (r'ya29\.[a-zA-Z0-9_-]{50,}',                   'Google OAuth token'),
    (r'(?i)(api[_-]?key|secret[_-]?key|access[_-]?token)\s*[=:]\s*["\']?[a-zA-Z0-9+/=_-]{30,}',
                                                     'hardcoded API key/secret'),
    (r'-----BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY-----', 'private key material'),
]

try:
    data = json.load(sys.stdin)
    fp = data.get("tool_input", {}).get("file_path", "") or ""
    content = data.get("tool_input", {}).get("content", "") or ""
except Exception:
    sys.exit(0)

# Skip example/template files — they're expected to have placeholder-looking values
lower_fp = fp.lower()
if any(x in lower_fp for x in ('.example', '.sample', '.template', 'fixture', 'test', 'mock', 'stub')):
    sys.exit(0)

hits = []
for pat, label in PATTERNS:
    if re.search(pat, content):
        hits.append(label)

if not hits:
    sys.exit(0)

msg = f"⚠ baron-secret: {fp} may contain real credentials: {', '.join(hits)}. Verify before writing."
print(json.dumps({
    "hookSpecificOutput": {
        "hookEventName": "PreToolUse",
        "additionalContext": msg
    }
}))
PYEOF
